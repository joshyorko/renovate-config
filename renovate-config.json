{
  "$schema": "https://docs.renovatebot.com/renovate-schema.json",
  "onboarding": false,
  "platform": "github",
  "autodiscover": true,
  "autodiscoverFilter": [
    "joshyorko/dsb-common",
    "joshyorko/dudley-os",
    "joshyorko/homebrew-tools",
    "joshyorko/rcc",
    "joshyorko/room-of-requirement"
  ],
  "requireConfig": "required",
  "inheritConfig": true,
  "inheritConfigRepoName": "joshyorko/renovate-config",
  "inheritConfigFileName": "org-inherited-config.json",
  "inheritConfigStrict": true
}
